riscv: use generic UP atomics when building without A

RiscVEmulator is single-hart and now builds the RV32 kernel for plain
rv32i_zicsr_zifencei. The upstream RISC-V atomic, bitops, xchg and
cmpxchg helpers are written directly in terms of LR/SC/AMO instructions,
so compiling a no-A kernel would leave literal A-extension opcodes even
though -march no longer contains `a`.

For the non-SMP RV32 nommu kernel used here, use the generic UP atomic
and bitop implementations, and provide xchg/cmpxchg with local IRQs
disabled. This is single-hart safe and contains no LR/SC/AMO instruction.

Signed-off-by: Examples.Linux.Build_RV32i <rvemu@localhost>
--- a/arch/riscv/include/asm/atomic.h
+++ b/arch/riscv/include/asm/atomic.h
@@ -7,6 +7,18 @@
 #ifndef _ASM_RISCV_ATOMIC_H
 #define _ASM_RISCV_ATOMIC_H
 
+#ifndef CONFIG_SMP
+#ifdef CONFIG_GENERIC_ATOMIC64
+# include <asm-generic/atomic64.h>
+#else
+# if (__riscv_xlen < 64)
+#  error "64-bit atomics require XLEN to be at least 64"
+# endif
+#endif
+#include <asm-generic/atomic.h>
+
+#else /* CONFIG_SMP */
+
 #ifdef CONFIG_GENERIC_ATOMIC64
 # include <asm-generic/atomic64.h>
 #else
@@ -325,4 +336,6 @@ static __always_inline s64 arch_atomic64_dec_if_positive(atomic64_t *v)
 #define arch_atomic64_dec_if_positive	arch_atomic64_dec_if_positive
 #endif
 
+#endif /* CONFIG_SMP */
+
 #endif /* _ASM_RISCV_ATOMIC_H */
--- a/arch/riscv/include/asm/bitops.h
+++ b/arch/riscv/include/asm/bitops.h
@@ -252,6 +252,43 @@
 
 #include <asm-generic/bitops/const_hweight.h>
 
+#ifndef CONFIG_SMP
+#include <asm-generic/bitops/atomic.h>
+#define set_bit			arch_set_bit
+#define clear_bit		arch_clear_bit
+#define change_bit		arch_change_bit
+#define test_and_set_bit	arch_test_and_set_bit
+#define test_and_clear_bit	arch_test_and_clear_bit
+#define test_and_change_bit	arch_test_and_change_bit
+
+static inline int test_and_set_bit_lock(unsigned long nr,
+					volatile unsigned long *addr)
+{
+	return arch_test_and_set_bit(nr, addr);
+}
+
+static inline void clear_bit_unlock(unsigned long nr,
+				    volatile unsigned long *addr)
+{
+	arch_clear_bit(nr, addr);
+}
+
+static inline void __clear_bit_unlock(unsigned long nr,
+				      volatile unsigned long *addr)
+{
+	clear_bit_unlock(nr, addr);
+}
+
+static inline bool xor_unlock_is_negative_byte(unsigned long mask,
+		volatile unsigned long *addr)
+{
+	unsigned long old = READ_ONCE(*addr);
+	WRITE_ONCE(*addr, old ^ mask);
+	return (old & BIT(7)) != 0;
+}
+
+#else /* CONFIG_SMP */
+
 #if (BITS_PER_LONG == 64)
 #define __AMO(op)	"amo" #op ".d"
 #elif (BITS_PER_LONG == 32)
@@ -457,6 +481,8 @@ static inline bool xor_unlock_is_negative_byte(unsigned long mask,
 #undef __NOT
 #undef __AMO
 
+#endif /* CONFIG_SMP */
+
 #include <asm-generic/bitops/non-atomic.h>
 #include <asm-generic/bitops/le.h>
 #include <asm-generic/bitops/ext2-atomic.h>
--- a/arch/riscv/include/asm/cmpxchg.h
+++ b/arch/riscv/include/asm/cmpxchg.h
@@ -10,6 +10,133 @@
 #include <asm/barrier.h>
 #include <asm/fence.h>
 
+#ifndef CONFIG_SMP
+
+#include <linux/compiler.h>
+#include <linux/irqflags.h>
+#include <linux/types.h>
+
+#define __rvemu_read_once(ptr, size)					\
+({									\
+	__typeof__(*(ptr)) __ret;					\
+	switch (size) {							\
+	case 4:								\
+		__ret = (__typeof__(*(ptr)))READ_ONCE(*(u32 *)(ptr));	\
+		break;							\
+	case 8:								\
+		__ret = (__typeof__(*(ptr)))READ_ONCE(*(u64 *)(ptr));	\
+		break;							\
+	default:							\
+		BUILD_BUG();						\
+	}								\
+	__ret;								\
+})
+
+#define __rvemu_write_once(ptr, val, size)				\
+do {									\
+	switch (size) {							\
+	case 4:								\
+		WRITE_ONCE(*(u32 *)(ptr), (u32)(val));			\
+		break;							\
+	case 8:								\
+		WRITE_ONCE(*(u64 *)(ptr), (u64)(val));			\
+		break;							\
+	default:							\
+		BUILD_BUG();						\
+	}								\
+} while (0)
+
+#define __rvemu_xchg(ptr, new, size)					\
+({									\
+	__typeof__(ptr) __ptr = (ptr);					\
+	__typeof__(new) __new = (new);					\
+	__typeof__(*(ptr)) __ret;					\
+	unsigned long __flags;						\
+	raw_local_irq_save(__flags);					\
+	__ret = __rvemu_read_once(__ptr, size);				\
+	__rvemu_write_once(__ptr, __new, size);				\
+	raw_local_irq_restore(__flags);					\
+	__ret;								\
+})
+
+#define arch_xchg_relaxed(ptr, x)					\
+({									\
+	__typeof__(*(ptr)) _x_ = (x);					\
+	(__typeof__(*(ptr)))__rvemu_xchg((ptr), _x_, sizeof(*(ptr)));	\
+})
+
+#define arch_xchg_acquire(ptr, x)					\
+({									\
+	__typeof__(*(ptr)) __ret = arch_xchg_relaxed((ptr), (x));	\
+	__asm__ __volatile__(RISCV_ACQUIRE_BARRIER "" ::: "memory");	\
+	__ret;								\
+})
+
+#define arch_xchg_release(ptr, x)					\
+({									\
+	__asm__ __volatile__(RISCV_RELEASE_BARRIER "" ::: "memory");	\
+	arch_xchg_relaxed((ptr), (x));					\
+})
+
+#define arch_xchg(ptr, x)						\
+({									\
+	__typeof__(*(ptr)) __ret = arch_xchg_relaxed((ptr), (x));	\
+	__asm__ __volatile__("fence rw, rw" ::: "memory");		\
+	__ret;								\
+})
+
+#define xchg32(ptr, x)							\
+({									\
+	BUILD_BUG_ON(sizeof(*(ptr)) != 4);				\
+	arch_xchg((ptr), (x));						\
+})
+
+#define xchg64(ptr, x)							\
+({									\
+	BUILD_BUG_ON(sizeof(*(ptr)) != 8);				\
+	arch_xchg((ptr), (x));						\
+})
+
+#define __rvemu_cmpxchg(ptr, old, new, size)				\
+({									\
+	__typeof__(ptr) __ptr = (ptr);					\
+	__typeof__(*(ptr)) __old = (old);				\
+	__typeof__(*(ptr)) __new = (new);				\
+	__typeof__(*(ptr)) __ret;					\
+	unsigned long __flags;						\
+	raw_local_irq_save(__flags);					\
+	__ret = __rvemu_read_once(__ptr, size);				\
+	if (__ret == __old)						\
+		__rvemu_write_once(__ptr, __new, size);			\
+	raw_local_irq_restore(__flags);					\
+	__ret;								\
+})
+
+#define arch_cmpxchg_relaxed(ptr, o, n)					\
+	((__typeof__(*(ptr)))__rvemu_cmpxchg((ptr), (o), (n), sizeof(*(ptr))))
+#define arch_cmpxchg_acquire(ptr, o, n)					\
+({									\
+	__typeof__(*(ptr)) __ret = arch_cmpxchg_relaxed((ptr), (o), (n)); \
+	__asm__ __volatile__(RISCV_ACQUIRE_BARRIER "" ::: "memory");	\
+	__ret;								\
+})
+#define arch_cmpxchg_release(ptr, o, n)					\
+({									\
+	__asm__ __volatile__(RISCV_RELEASE_BARRIER "" ::: "memory");	\
+	arch_cmpxchg_relaxed((ptr), (o), (n));				\
+})
+#define arch_cmpxchg(ptr, o, n)						\
+({									\
+	__typeof__(*(ptr)) __ret = arch_cmpxchg_relaxed((ptr), (o), (n)); \
+	__asm__ __volatile__("fence rw, rw" ::: "memory");		\
+	__ret;								\
+})
+#define arch_cmpxchg_local(ptr, o, n) arch_cmpxchg_relaxed((ptr), (o), (n))
+#define arch_cmpxchg64(ptr, o, n) arch_cmpxchg((ptr), (o), (n))
+#define arch_cmpxchg64_local(ptr, o, n) arch_cmpxchg_relaxed((ptr), (o), (n))
+
+#else /* CONFIG_SMP */
+
 #define __xchg_relaxed(ptr, new, size)					\
 ({									\
 	__typeof__(ptr) __ptr = (ptr);					\
@@ -376,4 +494,6 @@
 	arch_cmpxchg_relaxed((ptr), (o), (n));				\
 })
 
+#endif /* CONFIG_SMP */
+
 #endif /* _ASM_RISCV_CMPXCHG_H */
