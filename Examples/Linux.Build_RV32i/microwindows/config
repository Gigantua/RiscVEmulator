# rvemu Microwindows config — cross-build for nommu uclibc + BFLT
ARCH                     = UCLINUX-RISCV
RISCVTOOLSPREFIX         = $(HOME)/rvemu-buildroot/output/host/bin/riscv32-buildroot-linux-uclibc-
SHAREDLIBS               = N
SHAREDLINK               = N
DEBUG                    = N
OPTIMIZE                 = Y
VERBOSE                  = N
THREADSAFE               = N
PARALLEL                 = N

# Direct-mapped /dev/mem framebuffer at 0x85C00000 (see scr_rvemu.c)
SCREEN                   = RVEMU
SCREEN_PIXTYPE           = MWPF_TRUECOLORABGR
SCREEN_WIDTH             = 1024
SCREEN_HEIGHT            = 768
SCREEN_DEPTH             = 32

# Input: rvemu-input daemon publishes /dev/input/event0+1
MOUSE                    = DEVMICEMOUSE
KEYBOARD                 = RVEMU

MICROWIN                 = N
NANOX                    = Y
NUKLEARUI                = N
NX11                     = N
ENGINE                   = N
TINYWIDGETS              = N

FBEMULATOR               = N
MICROWINDEMO             = N
MICROWINMULTIAPP         = N
NANOXDEMO                = Y
HAVE_VNCSERVER_SUPPORT   = N

# Build a standalone nano-X server + separate client binaries (vs the
# default Y which links the server into every demo). Lets us run multiple
# nano-X clients on one server (nanowm + nxclock + nxeyes ...) over the
# socket at /tmp/.nano-X. Requires AUTO_START_SERVER=0 in mwconfig.h —
# our patch already disables that since nommu has no fork().
LINK_APP_INTO_SERVER     = N
NANOWM                   = Y

HAVE_SHAREDMEM_SUPPORT   = Y
HAVE_FILEIO              = Y
HAVE_BMP_SUPPORT         = N
HAVE_GIF_SUPPORT         = Y
HAVE_PNM_SUPPORT         = N
HAVE_XPM_SUPPORT         = N
HAVE_JPEG_SUPPORT        = N
HAVE_PNG_SUPPORT         = N
HAVE_FREETYPE_2_SUPPORT  = N
HAVE_HARFBUZZ_SUPPORT    = N
HAVE_FRIBIDI_SUPPORT     = N
HAVE_T1LIB_SUPPORT       = N
HAVE_HZK_SUPPORT         = N
HAVE_BIG5_SUPPORT        = N
HAVE_GB2312_SUPPORT      = N
HAVE_JISX0213_SUPPORT    = N
HAVE_KSC5601_SUPPORT     = N
HAVE_EUCJP_SUPPORT       = N
HAVE_FNT_SUPPORT         = N
HAVE_PCF_SUPPORT         = N
HAVE_AGG_SUPPORT         = N
