    <None Update="Programs\double_basics.c" CopyToOutputDirectory="Always" />
    <None Update="Programs\double_matmul.c" CopyToOutputDirectory="Always" />
    <None Update="Programs\timer_test.c"   CopyToOutputDirectory="Always" />
