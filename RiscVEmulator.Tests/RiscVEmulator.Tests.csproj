<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Produces a self-contained test exe using the new Microsoft Testing Platform -->
    <EnableMSTestRunner>true</EnableMSTestRunner>
  </PropertyGroup>

  <ItemGroup>
    <!-- All-in-one MSTest 3.x package (framework + adapter + MTP runner) -->
    <PackageReference Include="MSTest" Version="3.8.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Core\RiscVEmulator.Core.csproj" />
  </ItemGroup>

  <!-- Copy C sources, linker script and runtime to the test output directory -->
  <ItemGroup>
    <None Update="Programs\linker.ld"       CopyToOutputDirectory="Always" />
    <None Update="Programs\primes.c"        CopyToOutputDirectory="Always" />
    <None Update="Programs\fibonacci.c"     CopyToOutputDirectory="Always" />
    <None Update="Programs\bubblesort.c"    CopyToOutputDirectory="Always" />
    <None Update="Programs\bitops.c"        CopyToOutputDirectory="Always" />
    <None Update="Programs\mem_widths.c"    CopyToOutputDirectory="Always" />
    <None Update="Programs\signed_ops.c"    CopyToOutputDirectory="Always" />
    <None Update="Programs\uint64_ops.c"    CopyToOutputDirectory="Always" />
    <None Update="Programs\factorial.c"     CopyToOutputDirectory="Always" />
